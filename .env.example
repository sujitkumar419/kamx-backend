# Copy this file to .env (locally) or set these as environment
# variables in your Railway / Render dashboard.

# Local dev default: SQLite file. In production, use your Postgres URL
# from Supabase/Railway, e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./kamx.db

# Any long random string — used to sign login tokens. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_long_random_string

# Password to access the admin dashboard at /admin.html (set your own!)
ADMIN_PASSWORD=change_this_to_your_own_password

# Razorpay test/live keys (leave blank to keep bookings auto-confirmed without payment)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
